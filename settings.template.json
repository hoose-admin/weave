{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/skill_reflect.py\"",
            "timeout": 5,
            "statusMessage": "Arming skill-reflection…"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/skill_reflect.py\"",
            "timeout": 10,
            "statusMessage": "Reflecting on skill/script learnings…"
          }
        ]
      }
    ]
  }
}
