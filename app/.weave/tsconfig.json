{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["bun"]
  },
  "include": ["server.ts", "weave.config.ts", "lib/**/*.ts", "scripts/**/*.ts"]
}
